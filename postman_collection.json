  },
  "item": [
    {
      "name": "Crear Orden",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "http://localhost:8000/orders",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customer\": \"Juan Pérez\",\n  \"items\": [\n    {\"sku\": \"A1\", \"qty\": 2},\n    {\"sku\": \"B2\", \"qty\": 1}\n  ]\n}"
        }
      }
    },
    {
      "name": "Consultar Orden",
      "request": {
        "method": "GET",
