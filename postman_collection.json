      }
    },
    {
      "name": "Ver Notificaciones (Notification)",
      "request": {
        "method": "GET",
        "url": "http://localhost:8004/notifications"
      }
    },
    {
      "name": "Health Check Inventory",
      "request": {
        "method": "GET",
        "url": "http://localhost:8002/health"
      }
    },
    {
      "name": "Health Check Analytics",
      "request": {
        "method": "GET",
        "url": "http://localhost:8003/health"
      }
    },
    {
      "name": "Health Check Notification",
      "request": {
        "method": "GET",
        "url": "http://localhost:8004/health"
      }
