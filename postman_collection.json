{
  "info": {
    "name": "Ordenes Distribuidas",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Crear Orden",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "http://localhost:8000/orders",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customer\": \"Carlos\",\n  \"items\": [{\"sku\": \"001-E\", \"qty\": 2}]\n}"
        }
      }
    },
    {
      "name": "Consultar Orden",
      "request": {
        "method": "GET",
        "url": "http://localhost:8000/orders/{{order_id}}"
      }
    },
    {
      "name": "Ver Stock (Inventory)",
      "request": {
        "method": "GET",
        "url": "http://localhost:8002/stock"
      }
    },
    {
      "name": "Ver Notificaciones",
      "request": {
        "method": "GET",
        "url": "http://localhost:8004/notifications"
      }
    },
    {
      "name": "Health Check (API Gateway)",
      "request": {
        "method": "GET",
        "url": "http://localhost:8000/health"
      }
    }
  ],
  "variable": [
    { "key": "order_id", "value": "" }
  ]
}